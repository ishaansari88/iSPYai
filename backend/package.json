{
  "name": "@ispyai/backend",
  "version": "0.1.0",
  "private": true,
  "description": "iSpyAI remote-monitoring backend (Express + Socket.IO).",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.json",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test src/__tests__/*.test.ts"
  },
  "dependencies": {
    "@ispyai/shared": "*",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "nanoid": "^5.0.7",
    "pino": "^9.2.0",
    "pino-pretty": "^11.2.1",
    "socket.io": "^4.7.5",
    "ws": "^8.17.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.12",
    "@types/ws": "^8.5.10",
    "tsx": "^4.11.0",
    "typescript": "^5.4.5"
  }
}
