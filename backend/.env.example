# Backend HTTP/WebSocket port. The dashboard's Vite proxy points at this.
PORT=4000

# Comma-separated CORS allowlist. Leave blank to allow all origins (dev only).
# Example: https://dashboard.example.com,https://qa.example.com
CORS_ORIGINS=

# Logging level for pino: trace | debug | info | warn | error
LOG_LEVEL=info

# Idle-session TTL. Sessions inactive longer than this are evicted. Default 24h.
SESSION_TTL_MS=86400000

# Debounce window for per-session AI report recomputation, in milliseconds.
ANALYSIS_DEBOUNCE_MS=1000
